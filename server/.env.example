# Server
PORT=5050
NODE_ENV=development

# MongoDB (local dev or MongoDB Atlas connection string)
MONGODB_URI=mongodb://127.0.0.1:27017/sazia_crm

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS — comma-separated allowed origins (the client URL)
CLIENT_ORIGIN=http://localhost:5173

# First admin (used by `npm run seed`)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@sazia.local
SEED_ADMIN_PASSWORD=admin12345
